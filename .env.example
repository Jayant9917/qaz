# NOVO environment
NOVO_ENVIRONMENT=development
NOVO_LOG_LEVEL=INFO
NOVO_API_HOST=0.0.0.0
NOVO_API_PORT=8000
NOVO_FRONTEND_ORIGIN=http://localhost:3000
NOVO_REQUIRE_INFRASTRUCTURE_FOR_READINESS=false

# PostgreSQL
NOVO_POSTGRES_HOST=localhost
NOVO_POSTGRES_PORT=5432
NOVO_POSTGRES_DB=novo
NOVO_POSTGRES_USER=novo
NOVO_POSTGRES_PASSWORD=change-me-development-only

# Redis
NOVO_REDIS_HOST=localhost
NOVO_REDIS_PORT=6379
NOVO_REDIS_DB=0

# Browser frontend
NEXT_PUBLIC_NOVO_API_URL=http://localhost:8000/api/v1

# Secrets such as OpenRouter keys are intentionally absent.
# They will be configured through NOVO's Secrets Provider in later phases.
