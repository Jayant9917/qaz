{
  "name": "novo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.34.4",
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File scripts/dev.ps1 -Target all",
    "dev:backend": "powershell -ExecutionPolicy Bypass -File scripts/dev.ps1 -Target backend",
    "dev:frontend": "powershell -ExecutionPolicy Bypass -File scripts/dev.ps1 -Target frontend",
    "dev:infra": "powershell -ExecutionPolicy Bypass -File scripts/dev.ps1 -Target infra",
    "build": "pnpm --filter @novo/frontend build",
    "lint": "pnpm --filter @novo/frontend lint",
    "typecheck": "pnpm --filter @novo/frontend typecheck",
    "test": "pnpm --filter @novo/frontend test",
    "quality": "pnpm lint && pnpm typecheck && pnpm test"
  }
}